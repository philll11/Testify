{
  "name": "backend",
  "version": "2.0.0",
  "description": "",
  "author": "",
  "private": true,
  "license": "UNLICENSED",
  "scripts": {
    "build": "nest build",
    "format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\"",
    "start": "nest start",
    "start:dev": "nest start --watch",
    "start:debug": "nest start --debug --watch",
    "start:prod": "node dist/main",
    "lint": "eslint \"{src,apps,libs,test}/**/*.ts\" --fix",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:cov": "jest --coverage",
    "test:debug": "node --inspect-brk -r tsconfig-paths/register -r ts-node/register node_modules/.bin/jest --runInBand",
    "test:e2e:role:all": "npm run test:e2e:role:crud && npm run test:e2e:role:auth && npm run test:e2e:role:advanced",
    "test:e2e:role:crud": "jest --config ./test/jest-e2e.json test/role/role.crud.e2e-spec.ts --verbose",
    "test:e2e:role:auth": "jest --config ./test/jest-e2e.json test/role/role.auth.e2e-spec.ts --verbose",
    "test:e2e:role:advanced": "jest --config ./test/jest-e2e.json test/role/role.advanced.e2e-spec.ts --verbose",
    "test:e2e:user:all": "npm run test:e2e:user:crud && npm run test:e2e:user:auth && npm run test:e2e:user:audit && npm run test:e2e:user:advanced",
    "test:e2e:user:crud": "jest --config ./test/jest-e2e.json test/user/user.crud.e2e-spec.ts --verbose",
    "test:e2e:user:auth": "jest --config ./test/jest-e2e.json test/user/user.auth.e2e-spec.ts --verbose",
    "test:e2e:user:audit": "jest --config ./test/jest-e2e.json test/user/user.audit.e2e-spec.ts --verbose",
    "test:e2e:user:advanced": "jest --config ./test/jest-e2e.json test/user/user.advanced.e2e-spec.ts --verbose",
    "test:e2e:counter:all": "npm run test:e2e:counter:crud && npm run test:e2e:counter:auth && npm run test:e2e:counter:advanced",
    "test:e2e:counter:crud": "jest --config ./test/jest-e2e.json test/counter/counter.crud.e2e-spec.ts --verbose",
    "test:e2e:counter:auth": "jest --config ./test/jest-e2e.json test/counter/counter.auth.e2e-spec.ts --verbose",
    "test:e2e:counter:advanced": "jest --config ./test/jest-e2e.json test/counter/counter.advanced.e2e-spec.ts --verbose",
    "test:e2e:system-config:all": "npm run test:e2e:system-config:crud && npm run test:e2e:system-config:auth",
    "test:e2e:system-config:crud": "jest --config ./test/jest-e2e.json test/system-config/system-config.crud.e2e-spec.ts --verbose",
    "test:e2e:system-config:auth": "jest --config ./test/jest-e2e.json test/system-config/system-config.auth.e2e-spec.ts --verbose",
    "test:e2e:audit": "jest --config ./test/jest-e2e.json test/audit/audit.e2e-spec.ts --verbose",
    "test:e2e:auth:recovery": "jest --config ./test/jest-e2e.json test/auth/auth.password-recovery.e2e-spec.ts --verbose",
    "test:e2e:platform-env": "jest --config ./test/jest-e2e.json test/platform/platform-environment.e2e-spec.ts --verbose",
    "test:e2e:platform-prof": "jest --config ./test/jest-e2e.json test/platform/platform-profile.e2e-spec.ts --verbose",
    "test:e2e:discovery": "jest --config ./test/jest-e2e.json test/discovery/discovery.e2e-spec.ts --verbose",
    "test:e2e:discovery-comp": "jest --config ./test/jest-e2e.json test/discovery/discovery.component.e2e-spec.ts --verbose",
    "test:e2e": "npm run test:e2e:role:all && npm run test:e2e:user:all && npm run test:e2e:counter:all && npm run test:e2e:system-config:all && npm run test:e2e:audit && npm run test:e2e:auth:recovery && npm run test:e2e:platform-env && npm run test:e2e:platform-prof && npm run test:e2e:discovery",
    "test:e2e:boomi-live": "jest --config ./test/jest-e2e.json test/boomi/boomi-live.e2e-spec.ts --verbose",
    "seed": "ts-node src/seed.ts",
    "seed:prod": "node dist/seed.js"
  },
  "dependencies": {
    "@nestjs/common": "11.0.1",
    "@nestjs/config": "4.0.2",
    "@nestjs/core": "11.0.1",
    "@nestjs/event-emitter": "^3.0.1",
    "@nestjs/jwt": "11.0.0",
    "@nestjs/mapped-types": "2.1.0",
    "@nestjs/passport": "11.0.5",
    "@nestjs/platform-express": "11.0.1",
    "@nestjs/schedule": "6.1.1",
    "@nestjs/swagger": "11.2.0",
    "@nestjs/typeorm": "11.0.0",
    "axios": "1.13.5",
    "bcrypt": "6.0.0",
    "class-transformer": "0.5.1",
    "class-validator": "0.14.2",
    "cookie-parser": "1.4.7",
    "cron": "4.4.0",
    "jsonwebtoken": "9.0.2",
    "nestjs-pino": "4.4.1",
    "passport": "0.7.0",
    "passport-jwt": "4.0.1",
    "passport-local": "1.0.0",
    "pg": "8.18.0",
    "pino-http": "10.5.0",
    "pino-pretty": "13.1.2",
    "reflect-metadata": "0.2.2",
    "rxjs": "7.8.1",
    "typeorm": "0.3.28"
  },
  "devDependencies": {
    "@eslint/eslintrc": "3.2.0",
    "@eslint/js": "9.18.0",
    "@nestjs/cli": "11.0.0",
    "@nestjs/schematics": "11.0.0",
    "@nestjs/testing": "11.0.1",
    "@types/bcrypt": "6.0.0",
    "@types/cookie-parser": "1.4.10",
    "@types/cron": "2.0.1",
    "@types/express": "5.0.0",
    "@types/jest": "30.0.0",
    "@types/node": "22.10.7",
    "@types/passport-jwt": "4.0.1",
    "@types/passport-local": "1.0.38",
    "@types/supertest": "6.0.2",
    "eslint": "9.18.0",
    "eslint-config-prettier": "10.0.1",
    "eslint-plugin-prettier": "5.2.2",
    "globals": "16.0.0",
    "jest": "29.7.0",
    "mongodb-memory-server": "10.2.0",
    "prettier": "3.4.2",
    "source-map-support": "0.5.21",
    "supertest": "7.0.0",
    "ts-jest": "29.2.5",
    "ts-loader": "9.5.2",
    "ts-node": "10.9.2",
    "tsconfig-paths": "4.2.0",
    "typescript": "5.7.3",
    "typescript-eslint": "8.20.0"
  },
  "jest": {
    "moduleFileExtensions": [
      "js",
      "json",
      "ts"
    ],
    "rootDir": "src",
    "testRegex": ".*\\.spec\\.ts$",
    "transform": {
      "^.+\\.(t|j)s$": "ts-jest"
    },
    "collectCoverageFrom": [
      "**/*.(t|j)s"
    ],
    "coverageDirectory": "../coverage",
    "testEnvironment": "node"
  }
}