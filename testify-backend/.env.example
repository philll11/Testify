# Environment configuration template

# Server Configuration
NODE_ENV=development
APP_ENV=local
PORT=3431

# Database Configuration (PostgreSQL)
DATABASE_HOST=localhost
DATABASE_PORT=3430
DATABASE_USER=postgres
DATABASE_PASSWORD=your_secure_password
DATABASE_NAME=testify_db
DATABASE_SYNCHRONIZE=false

# Production DB SSL toggle (Set to 'true' for Azure/Cloud, leaving empty or 'false' defaults to plaintext locally)
DATABASE_SSL=false

# Redis Configuration (BullMQ)
REDIS_HOST=localhost
REDIS_PORT=6380
REDIS_DB=0
# Optional Redis password (useful for production)
REDIS_PASSWORD=

# Production Redis TLS toggle (Set to 'true' for Azure/Cloud, leaving empty or 'false' defaults to plaintext locally)
REDIS_TLS=false

# Admin User Seed
ADMIN_EMAIL=test@testify.com
ADMIN_FIRST_NAME=Admin
ADMIN_LAST_NAME=User

# Auth & Security
JWT_SECRET=your_jwt_secret_key_here
JWT_EXPIRES_IN_SECONDS=86400

# Logging Options
LOG_LEVEL=debug

# CORS & Frontend URLs
CORS_ORIGIN=http://localhost:3432
FRONTEND_URL=http://localhost:3432